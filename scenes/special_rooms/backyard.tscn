[sub_resource type="GDScript" id="GDScript_noyvb"]
resource_name = "random_anim_offset"
script/source = "extends Node2D

func _ready() -> void:
	for person in get_children():
		if person is AnimatedSprite2D:
			person.set_frame_and_progress(randi_range(0, 1), randf_range(0.0, 1.0))
			person.speed_scale = randf_range(0.5, 1.5)
"

[sub_resource type="GDScript" id="GDScript_ijwvq"]
resource_name = "WinCheck"
script/source = "extends Area2D

func _on_body_entered(body: Node2D) -> void:
	if body is PlayerCharacter:
		if \"Drums\" in body.inventory and \"Synth\" in body.inventory:
			SceneTransitions.end_game()
"

