; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Stars Without Constellations"
run/main_scene="uid://d1hcfdareypq1"
run/print_header=false
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://assets/icon.svg"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/window_width_override=1920
window/size/window_height_override=1280
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray()

[global]

TILE_WIDTH=8
viewport_size=Vector2i(320, 180)
viewport_size_T=Vector2(40, 22.5)
room_size=Vector2i(320, 184)
room_size_T=Vector2i(40, 23)

